# RESEND_API_KEY: API key from resend.com to send emails
RESEND_API_KEY=

# GOOGLE_SERVICE_ACCOUNT_EMAIL: Client email from Google Service Account JSON
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# GOOGLE_PRIVATE_KEY: Private key from Google Service Account JSON (include \n)
GOOGLE_PRIVATE_KEY=

# GOOGLE_SPREADSHEET_ID: The ID of the Google Sheet (from the URL)
GOOGLE_SPREADSHEET_ID=
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
